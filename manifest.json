{
  "name": "Hello Extensions",
  "description": "Base Level Extension",
  "version": "1.0",
  "manifest_version": 3,
  "permissions": 
    [
      "storage", 
      "tabs", 
      "scripting"
    ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "dist/popup.html",
    "default_icon": "test_photo.png"
  }
}